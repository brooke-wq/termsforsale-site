# Copy this file to .env and fill in the values.
#
# Port the Express server listens on.
PORT=3001

# Shared secret that callers (n8n, curl, etc.) must send in the X-Auth-Token header.
# Generate a long random string. Example:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_TOKEN=change-me-to-a-long-random-string

# OAuth client credentials from Google Cloud Console
# (APIs & Services -> Credentials -> Create OAuth Client ID -> Web application).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Refresh token minted via `node get-refresh-token.js` (one-shot local script).
GOOGLE_REFRESH_TOKEN=

# ID of the Drive folder that uploaded files land in.
# Open the folder in Drive. The URL looks like:
#   https://drive.google.com/drive/folders/1aBc2DeFGhIjKlMnOpQrStUvWxYz
# DRIVE_FOLDER_ID is the last path segment.
DRIVE_FOLDER_ID=
