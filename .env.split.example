# GHL Sub-Account Split — Environment Variables Template
#
# Copy this to .env (or paste these into Netlify + droplet /etc/environment)
# AFTER completing Phase 1 (sub-account creation). Phase 2 code reads these.
#
# Naming rule: brand-suffixed vars take priority. The legacy unsuffixed
# vars (GHL_API_KEY, GHL_LOCATION_ID, etc.) are kept during transition as
# a fallback so unmigrated functions don't break. Phase 5 cleanup removes
# the legacy vars.
# ============================================================================

# ---------- Terms For Sale (existing — buyer side) ----------
GHL_API_TOKEN_TFS=pit-existing-tfs-token
GHL_LOCATION_ID_TFS=7IyUgu1zpi38MDYpSDTs
BROOKE_CONTACT_ID_TFS=1HMBtAv9EuTlJa5EekAL
CAMPAIGN_FROM_PHONE_TFS=+14806373117
CAMPAIGN_FROM_EMAIL_TFS=Terms For Sale <info@termsforsale.com>

# ---------- Dispo Buddy (NEW — JV partners) ----------
# Created in Phase 1 Step 1
GHL_API_TOKEN_DB=pit-FILL-AFTER-CREATE
GHL_LOCATION_ID_DB=FILL-AFTER-CREATE
BROOKE_CONTACT_ID_DB=FILL-AFTER-STEP-6
# Use the existing DID Brooke ports in (Phase 1 Step 4). E.164 format.
CAMPAIGN_FROM_PHONE_DB=+1FILL
CAMPAIGN_FROM_EMAIL_DB=Dispo Buddy <partners@dispobuddy.com>

# ---------- Acquisitions (NEW — sellers/agents) ----------
# Created in Phase 1 Step 2
GHL_API_TOKEN_ACQ=pit-FILL-AFTER-CREATE
GHL_LOCATION_ID_ACQ=FILL-AFTER-CREATE
BROOKE_CONTACT_ID_ACQ=FILL-AFTER-STEP-6
CAMPAIGN_FROM_PHONE_ACQ=+1FILL
CAMPAIGN_FROM_EMAIL_ACQ=Acquisitions <acquisitions@mydealpros.com>

# ---------- Per-brand kill switches (Phase 2 wires these) ----------
# Set to "1" to silence outbound from a single brand without affecting others.
NOTIFY_KILLSWITCH_TFS=
NOTIFY_KILLSWITCH_DB=
NOTIFY_KILLSWITCH_ACQ=

# ---------- Legacy (kept during transition; remove in Phase 5) ----------
# These are the unsuffixed names ~80 existing functions still read. Keep
# them set to the TFS values so unmigrated functions keep talking to TFS.
GHL_API_KEY=pit-existing-tfs-token
GHL_LOCATION_ID=7IyUgu1zpi38MDYpSDTs
BROOKE_CONTACT_ID=1HMBtAv9EuTlJa5EekAL
