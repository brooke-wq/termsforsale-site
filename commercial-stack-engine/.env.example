# Commercial Stack Engine — environment configuration
# Copy this file to .env and fill in the values.
# DO NOT commit .env. The .gitignore in this directory excludes it.

# ---------- Postgres ----------
POSTGRES_DB=stack_engine
POSTGRES_USER=cse
POSTGRES_PASSWORD=                  # REQUIRED. Generate via: openssl rand -hex 24
POSTGRES_PORT=5433                  # host-side port (container always uses 5432)

# ---------- Scraper service ----------
SCRAPER_AUTH_TOKEN=                 # REQUIRED. Generate via: openssl rand -hex 32
SCRAPE_RATE_LIMIT_MS=4000           # min delay between requests per source
LOG_LEVEL=info                      # debug | info | warn | error

# ---------- Webshare proxy (residential IPs) ----------
# Sign up at https://www.webshare.io/ — pick the $10/mo "Residential Lite" tier
# Generate an API key under Dashboard → API Keys
WEBSHARE_API_KEY=                   # REQUIRED for production scraping

# ---------- Anthropic / Claude ----------
ANTHROPIC_API_KEY=                  # REQUIRED. From console.anthropic.com
CLAUDE_MODEL=claude-haiku-4-5-20251001  # NEVER change this to Sonnet/Opus — cost guardrail
CLAUDE_DAILY_BUDGET_USD=2.00        # daily Claude spend kill-switch (logged via claude_cost_log)

# ---------- GoHighLevel (GHL) ----------
# See README question #1 — confirm which sub-account hosts commercial leads
GHL_API_KEY=                        # REQUIRED. From the chosen sub-account
GHL_LOCATION_ID=                    # REQUIRED. Sub-account location ID
GHL_PIPELINE_ID_COMMERCIAL=         # GHL pipeline ID for commercial Stack leads
GHL_STAGE_STACK_CANDIDATE=          # Pipeline stage ID: "Stack Candidate — Call Now"

# ---------- SMS alerts ----------
BROOKE_PHONE=+15167120113           # see CLAUDE.md — Brooke's cell, used for HOT lead pings
BROOKE_GHL_CONTACT_ID=1HMBtAv9EuTlJa5EekAL  # Brooke's contact in TFS GHL (per CLAUDE.md)

# ---------- Buyer entity (for LOI generation) ----------
# See README question #2 — what entity name should appear on LOIs?
LOI_BUYER_ENTITY=Deal Pros LLC
LOI_BUYER_SIGNER_NAME=Brooke Froehlich
LOI_BUYER_TITLE=Manager
LOI_DEFAULT_INSPECTION_DAYS=30
LOI_DEFAULT_CLOSING_DAYS=60

# ---------- Daily digest ----------
DIGEST_EMAIL_TO=brooke@dealpros.io  # set this; defaults to Brooke if blank
SLACK_WEBHOOK_URL=                  # optional — Slack incoming webhook for #commercial-deals

# ---------- Killswitches ----------
GHL_PUSH_LIVE=false                 # set to true after E2E test passes
SMS_ALERTS_LIVE=false               # set to true after dry-run scoring looks right
LOI_AUTO_GENERATE=false             # always require manual approval per CRITICAL DO-NOTS
